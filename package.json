{
  "name": "sprite-anime",
  "private": true,
  "version": "0.1.0",
  "description": "AI image/video generation and sprite animation workflow desktop app",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "node scripts/prepare-cli-sidecar.mjs && tauri dev -c src-tauri/tauri.sidecar.conf.json",
    "tauri:build": "node scripts/prepare-cli-sidecar.mjs --release && tauri build -c src-tauri/tauri.sidecar.conf.json",
    "cli": "cargo run --manifest-path src-tauri/Cargo.toml --bin sprite-anime-cli --",
    "cli:build": "node scripts/prepare-cli-sidecar.mjs --release",
    "check:cli": "cargo check --manifest-path src-tauri/Cargo.toml --bin sprite-anime-cli",
    "test:matting": "node scripts/test-matting-algorithm.mjs",
    "test:workflow": "node scripts/test-workflow-state.mjs",
    "test:redraw": "node scripts/test-video-sprite-redraw.mjs",
    "test:workspace-ui": "node scripts/test-task-workspace.mjs",
    "check:lines": "node scripts/check-line-limit.mjs",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test": "npm run check:lines && npm run typecheck && npm run test:matting && npm run test:workflow && npm run test:redraw && npm run test:workspace-ui && npm run test:rust"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0",
    "typescript": "^5.5",
    "vite": "^6"
  },
  "dependencies": {
    "@tauri-apps/api": "^2"
  }
}
