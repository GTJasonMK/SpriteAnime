{
  "name": "sprite-anime",
  "private": true,
  "version": "0.1.0",
  "description": "AI图片生成与精灵图动画预览工具",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test:matting": "node scripts/test-matting-algorithm.mjs",
    "test:bounds": "node scripts/test-bounds-detection.mjs",
    "test:workflow": "node scripts/test-workflow-state.mjs",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test": "npm run typecheck && npm run test:matting && npm run test:bounds && npm run test:workflow && npm run test:rust"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0",
    "typescript": "^5.5",
    "vite": "^6"
  },
  "dependencies": {
    "@tauri-apps/api": "^2"
  }
}
